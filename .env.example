# 复制为 .env 后执行: docker compose up -d --build

MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=xhblogs
MYSQL_PORT=3306

XHBLOGS_PORT=3000
MANAGER_PORT=3001
CMS_API_PORT=8000

# 可选：煤球 AI 未在后台填写 api_key 时的回退（推荐在 设置→AI煤球配置 网页保存）
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# npm 镜像（构建失败 ECONNRESET 时可改用官方源）
NPM_REGISTRY=https://registry.npmmirror.com

# 网易云音乐开放平台（https://developer.music.163.com）
# 个人开发者请用 CLI 生成密钥：node scripts/netease-setup-keys.mjs generate
# 文档：https://developer.music.163.com/st/developer/document?docId=2327e302009c437eb02af48f63d6e514
# 若控制台已有私钥，可直接粘贴到 NETEASE_PRIVATE_KEY 并运行 node scripts/sync-netease-key.mjs
# AppID / AppSecret 在控制台应用详情；私钥为 PKCS8 单行（generate + sync-env 会自动写入）
NETEASE_APP_ID=
NETEASE_APP_SECRET=
NETEASE_PRIVATE_KEY=
# 可选：CLI OpenAPI 域名，默认 https://openncm.music.163.com
# NETEASE_OPENAPI_BASE=https://openncm.music.163.com
# NETEASE_DEVICE_ID=可选，自定义设备 ID
