# 复制为 .env 后执行: docker compose up -d --build

MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=xhblogs
MYSQL_PORT=3306

XHBLOGS_PORT=3000
MANAGER_PORT=3001
CMS_API_PORT=8000

# npm 镜像（构建失败 ECONNRESET 时可改用官方源）
NPM_REGISTRY=https://registry.npmmirror.com

# 酷狗牛方案 OpenAPI（扫码登录 / 歌单，由酷狗商务提供 pid、pkey）
# 文档：https://open.kugou.com/docs/iot-solution/#/OPENAPI/README?id=%e7%94%a8%e6%88%b7
KUGOU_IOT_PID=
KUGOU_IOT_PKEY=
