# 复制为 .env 后执行: docker compose up -d --build

MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=xhblogs
MYSQL_PORT=3306

XHBLOGS_PORT=3000
MANAGER_PORT=3001
CMS_API_PORT=8000

# npm 镜像（构建失败 ECONNRESET 时可改用官方源）
NPM_REGISTRY=https://registry.npmmirror.com

# 网易云音乐开放平台（https://developer.music.163.com）
# AppID / AppSecret 在控制台应用详情；私钥为 PKCS8 单行字符串（去掉 PEM 头尾与换行）
NETEASE_APP_ID=
NETEASE_APP_SECRET=
NETEASE_PRIVATE_KEY=
# 用户 OAuth 回调（须与开放平台控制台「授权回调页」一致）
NETEASE_REDIRECT_URI=http://localhost:3001/api/music/netease/auth/callback
# 可选：管理端公网地址，未设 NETEASE_REDIRECT_URI 时用于拼接回调
# BLOG_MANAGER_PUBLIC_URL=http://localhost:3001
# NETEASE_DEVICE_ID=可选，自定义设备 ID
