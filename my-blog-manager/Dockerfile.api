FROM python:3.11-slim
WORKDIR /app
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY cms_core ./cms_core
COPY siteConfig.ts ./siteConfig.ts
EXPOSE 8000
CMD ["uvicorn", "cms_core.main:app", "--host", "0.0.0.0", "--port", "8000"]
